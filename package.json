{
  "name": "agila-files",
  "version": "1.0.0",
  "private": true,
  "description": "Vector Surveillance Operations Platform with Sentinel Network",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "node --watch src/server.js",
    "check": "tsc --noEmit",
