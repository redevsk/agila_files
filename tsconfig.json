{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "public/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
